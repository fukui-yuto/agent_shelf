# LLM プロバイダー: claude / openai / gemini / ollama
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic API キー (LLM_PROVIDER=claude の場合に必要)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI 設定 (LLM_PROVIDER=openai の場合)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...
# LLM_BASE_URL=              # 任意: OpenAI互換API用 (vLLM, LM Studio 等)

# Google Gemini 設定 (LLM_PROVIDER=gemini の場合)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# GOOGLE_API_KEY=...

# Ollama 設定 (LLM_PROVIDER=ollama の場合)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_BASE_URL=http://localhost:11434

# エンベディングプロバイダー: local / openai
EMBEDDING_PROVIDER=local

# OpenAI API キー (EMBEDDING_PROVIDER=openai の場合に必要)
# OPENAI_API_KEY=sk-...
