# LLM Provider: claude / ollama
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic API Key (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama settings (when LLM_PROVIDER=ollama)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_BASE_URL=http://localhost:11434

# Embedding Provider: local / openai
EMBEDDING_PROVIDER=local

# OpenAI API Key (required when EMBEDDING_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
